.row.justify-content-center.mt-4
  .col-md-10.col-lg-8
    %h1.text-center.fw-bold.mb-4.text-primary Listing Items

    .table-responsive
      %table.table.table-striped.table-hover.shadow-sm
        %thead.thead-light
          %tr
            %th Name
            %th Vat
            %th Company
            %th.text-center Actions

        %tbody
          - @items.each do |item|
            %tr
              %td= item.name
              %td= item.vat
              %td= item.company.name
              %td.text-center
                = link_to 'Show', item, class: 'btn btn-outline-primary btn-sm me-1'
                = link_to 'Edit', edit_item_path(item), class: 'btn btn-outline-secondary btn-sm me-1'
                = link_to 'Destroy', item, method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-outline-danger btn-sm'

    .text-center.mt-3
      = link_to 'New Item', new_item_path, class: 'btn btn-primary btn-sm'
