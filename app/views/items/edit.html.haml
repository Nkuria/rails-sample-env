.row.justify-content-center.mt-4
  .col-md-6.col-lg-5
    %h1.text-center.fw-bold.mb-4.text-primary Editing Item

    = render 'form'

    .d-flex.justify-content-center.mt-3.gap-2
      = link_to 'Show', @item, class: 'btn btn-outline-primary btn-sm'
      = link_to 'Back', items_path, class: 'btn btn-outline-secondary btn-sm'
